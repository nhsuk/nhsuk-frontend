{#
  Renders inline SVG icon

  @example
  Output user icon:

  ```njk
  nhsukIcon("user")
  ```

  @example
  Output search icon with an accessible title:

  ```njk
  nhsukIcon("search", "Search site")
  ```

  @private
  @param {string} name - Icon name
  @param {string} [title=false] - Accessible name
#}
{% macro nhsukIcon(name, title=false) -%}
<svg class="nhsuk-icon nhsuk-icon__{{ name }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="34" height="34" focusable="false"{% if title %} role="img" aria-label="{{ title }}"{% else %} aria-hidden="true"{% endif %}>
{% if title %}
  <title>{{ title }}</title>
{% endif %}
{% if name == "arrow-left" %}
  <path d="M10.7 6.3c.4.4.4 1 0 1.4L7.4 11H19a1 1 0 0 1 0 2H7.4l3.3 3.3c.4.4.4 1 0 1.4a1 1 0 0 1-1.4 0l-5-5A1 1 0 0 1 4 12c0-.3.1-.5.3-.7l5-5a1 1 0 0 1 1.4 0Z"/>
{% elif name == "arrow-right" %}
  <path d="m14.7 6.3 5 5c.2.2.3.4.3.7 0 .3-.1.5-.3.7l-5 5a1 1 0 0 1-1.4-1.4l3.3-3.3H5a1 1 0 0 1 0-2h11.6l-3.3-3.3a1 1 0 1 1 1.4-1.4Z"/>
{% elif name == "arrow-right-circle" %}
  <path d="M12 2a10 10 0 0 0-10 9h11.7l-4-4a1 1 0 0 1 1.5-1.4l5.6 5.7a1 1 0 0 1 0 1.4l-5.6 5.7a1 1 0 0 1-1.5 0 1 1 0 0 1 0-1.4l4-4H2A10 10 0 1 0 12 2z"/>
{% elif name == "chevron-down" %}
  <path d="M17 10.9 12.6 15a1 1 0 0 1-1.4 0L7 11a1 1 0 1 1 1.4-1.4L12 13l3.5-3.5a1 1 0 1 1 1.4 1.4Z"/>
{% elif name == "chevron-right-circle" %}
  <path d="M12 2a10 10 0 1 1 0 20 10 10 0 0 1 0-20Zm-1.1 5a1 1 0 1 0-1.4 1.5L13 12l-3.5 3.5a1 1 0 0 0 1.4 1.4l4.2-4.2c.4-.4.4-1 0-1.4Z"/>
{% elif name == "cross" %}
  <path d="M17 18.5c-.4 0-.8-.1-1.1-.4l-10-10c-.6-.6-.6-1.6 0-2.1.6-.6 1.5-.6 2.1 0l10 10c.6.6.6 1.5 0 2.1-.3.3-.6.4-1 .4z M7 18.5c-.4 0-.8-.1-1.1-.4-.6-.6-.6-1.5 0-2.1l10-10c.6-.6 1.5-.6 2.1 0 .6.6.6 1.5 0 2.1l-10 10c-.3.3-.6.4-1 .4z"/>
{% elif name == "search" %}
  <path d="M19.71 18.29l-4.11-4.1a7 7 0 1 0-1.41 1.41l4.1 4.11a1 1 0 0 0 1.42 0 1 1 0 0 0 0-1.42zM5 10a5 5 0 1 1 5 5 5 5 0 0 1-5-5z"/>
{% elif name == "tick" %}
  <path d="M11.4 18.8a2 2 0 0 1-2.7.1h-.1L4 14.1a1.5 1.5 0 0 1 2.1-2L10 16l8.1-8.1a1.5 1.5 0 1 1 2.2 2l-8.9 9Z"/>
{% elif name == "user" %}
  <path d="M12 1a11 11 0 1 1 0 22 11 11 0 0 1 0-22Zm0 2a9 9 0 0 0-5 16.5V18a4 4 0 0 1 4-4h2a4 4 0 0 1 4 4v1.5A9 9 0 0 0 12 3Zm0 3a3.5 3.5 0 1 1-3.5 3.5A3.4 3.4 0 0 1 12 6Z"/>
{% endif %}
</svg>
{% endmacro %}
