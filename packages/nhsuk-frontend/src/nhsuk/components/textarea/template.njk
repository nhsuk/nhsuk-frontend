{% from "nhsuk/macros/attributes.njk" import nhsukAttributes %}
{% from "nhsuk/components/error-message/macro.njk" import errorMessage %}
{% from "nhsuk/components/hint/macro.njk" import hint %}
{% from "nhsuk/components/label/macro.njk" import label %}

{#- Set variant for this component #}
{%- set variant = params.variant -%}

{#- Set classes for this component #}
{%- set classNames = "nhsuk-textarea" -%}
{%- set classNamesFormGroup = "nhsuk-form-group" -%}

{%- if variant == "reverse" and (not params.classes or not "nhsuk-textarea--reverse" in params.classes) %}
  {% set classNames = classNames ~ " nhsuk-textarea--" ~ variant %}
{% endif %}

{%- if params.errorMessage %}
  {% set classNames = classNames ~ " nhsuk-textarea--error" %}
  {% set classNamesFormGroup = classNamesFormGroup ~ (" nhsuk-form-group--reverse" if variant == "reverse") ~ " nhsuk-form-group--error" %}
{% endif %}

{%- if params.classes %}
  {% set classNames = classNames ~ " " ~ params.classes %}
{% endif %}

{%- if params.formGroup.classes %}
  {% set classNamesFormGroup = classNamesFormGroup ~ " " ~ params.formGroup.classes %}
{% endif %}

{#- a record of other elements that we need to associate with the input using
  aria-describedby – for example hints or error messages -#}
{% set describedBy = params.describedBy if params.describedBy else "" %}
{%- set id = params.id if params.id else params.name -%}

<div class="{{ classNamesFormGroup }}" {{- nhsukAttributes(params.formGroup.attributes) }}>
  {{ label({
    html: params.label.html,
    text: params.label.text,
    id: params.label.id,
    classes: params.label.classes,
    attributes: params.label.attributes,
    size: params.label.size,
    variant: params.label.variant | default(variant),
    isPageHeading: params.label.isPageHeading,
    for: id
  }) | trim | indent(2) }}
{% if params.hint %}
  {% set hintId = id ~ "-hint" %}
  {% set describedBy = (describedBy ~ " " ~ hintId) | trim %}
  {{ hint({
    html: params.hint.html,
    text: params.hint.text,
    id: hintId,
    classes: params.hint.classes,
    attributes: params.hint.attributes,
    variant: params.hint.variant | default(variant)
  }) | trim | indent(2) }}
{% endif %}
{% if params.errorMessage %}
  {% set errorId = id ~ "-error" %}
  {% set describedBy = (describedBy ~ " " ~ errorId) | trim %}
  {{ errorMessage({
    html: params.errorMessage.html,
    text: params.errorMessage.text,
    visuallyHiddenText: params.errorMessage.visuallyHiddenText,
    id: errorId,
    classes: params.errorMessage.classes,
    attributes: params.errorMessage.attributes,
    variant: params.errorMessage.variant | default(variant)
  }) | trim | indent(2) }}
{% endif %}
{% if params.formGroup.beforeInput %}
  {{ params.formGroup.beforeInput.html | safe | trim | indent(2) if params.formGroup.beforeInput.html else params.formGroup.beforeInput.text }}
{% endif %}
  <textarea class="{{ classNames }}" id="{{ id }}" name="{{ params.name }}" rows="{{ params.rows | default(5, true) }}"
  {%- if params.spellcheck in [true, false] %} spellcheck="{{ params.spellcheck }}"{% endif %}
  {%- if params.disabled %} disabled{% endif %}
  {%- if describedBy %} aria-describedby="{{ describedBy }}"{% endif %}
  {%- if params.autocomplete %} autocomplete="{{ params.autocomplete }}"{% endif %}
  {{- nhsukAttributes(params.attributes) }}>{{ params.value }}</textarea>
{% if params.formGroup.afterInput %}
  {{ params.formGroup.afterInput.html | safe | trim | indent(2) if params.formGroup.afterInput.html else params.formGroup.afterInput.text }}
{% endif %}
</div>
