{% from "nhsuk/macros/attributes.njk" import nhsukAttributes %}

{#- Set classes for this component #}
{%- set classNames = "nhsuk-back-link" -%}

{%- if params.reverse and (not params.classes or not "nhsuk-back-link--reverse" in params.classes) %}
  {% set classNames = classNames ~ " nhsuk-back-link--reverse" %}
{% endif %}

{%- if params.classes %}
  {% set classNames = classNames ~ " " ~ params.classes %}
{% endif %}

{%- set backLinkText = params.html | safe | trim | indent(2) if params.html else (params.text | default("Back", true)) -%}
{%- set element = "button" if params.element == "button" else "a" -%}

<{{ element }} {%- if params.id %} id="{{ params.id }}"{% endif %} class="{{ classNames }}"
  {%- if element == "a" %} href="{{ params.href | default("#", true) }}"{% endif %}
  {{- nhsukAttributes(params.attributes) }}>
  {% if params.visuallyHiddenText %}
  <span class="nhsuk-u-visually-hidden">{{ params.visuallyHiddenText }}</span> {{ backLinkText }}
  {% else %}
  {{ backLinkText }}
  {% endif %}
</{{ element }}>
