{% from "nhsuk/macros/attributes.njk" import nhsukAttributes -%}

{#- Set variant for this component #}
{%- set variant = params.variant -%}

{#- Set classes for this component #}
{%- set classNames = "nhsuk-hint" -%}

{%- if variant == "reverse" and (not params.classes or not "nhsuk-hint--reverse" in params.classes) %}
  {% set classNames = classNames ~ " nhsuk-hint--" ~ variant %}
{% endif %}

{%- if params.classes %}
  {% set classNames = classNames ~ " " ~ params.classes %}
{% endif -%}

<div class="{{ classNames }}" {%- if params.id %} id="{{ params.id }}"{% endif %}
  {{- nhsukAttributes(params.attributes) }}>
  {{ params.html | safe | trim | indent(2) if params.html else params.text }}
</div>
