{
  "name": "nhsuk-frontend",
  "version": "9.3.0",
  "description": "NHS.UK frontend contains the code you need to start building user interfaces for NHS websites and services.",
  "homepage": "https://nhsuk.github.io/nhsuk-frontend/",
  "bugs": {
    "url": "https://github.com/nhsuk/nhsuk-frontend/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nhsuk/nhsuk-frontend.git"
  },
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "sass": "./dist/nhsuk/all.scss",
      "import": "./dist/nhsuk/all.mjs",
      "require": "./dist/nhsuk/all.js"
    },
    "./*": "./*",
    "./packages/*": {
      "sass": "./dist/nhsuk/*.scss",
      "import": "./dist/nhsuk/*.mjs",
      "require": "./dist/nhsuk/*.js"
    },
    "./packages/*.js": "./dist/nhsuk/*.mjs",
    "./packages/*.scss": "./dist/nhsuk/*.scss",
    "./package.json": "./package.json"
  },
  "main": "dist/nhsuk/all.js",
  "module": "dist/nhsuk/all.mjs",
  "sass": "dist/nhsuk/all.scss",
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "devDependencies": {
    "puppeteer": "^24.6.0"
  },
  "engines": {
    "node": "^20.9.0 || ^22.11.0"
  }
}
