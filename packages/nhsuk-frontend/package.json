{
  "name": "nhsuk-frontend",
  "version": "10.4.2",
  "description": "NHS.UK frontend contains the code you need to start building user interfaces for NHS websites and services.",
  "homepage": "https://nhsuk.github.io/nhsuk-frontend/",
  "bugs": {
    "url": "https://github.com/nhsuk/nhsuk-frontend/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nhsuk/nhsuk-frontend.git"
  },
  "license": "MIT",
  "sideEffects": false,
  "imports": {
    "#lib": "./src/nhsuk/lib/index.mjs",
    "#lib/*": "./src/nhsuk/lib/*"
  },
  "exports": {
    ".": {
      "types": "./dist/nhsuk/index.d.mts",
      "sass": "./dist/nhsuk/index.scss",
      "import": "./dist/nhsuk/index.mjs",
      "require": "./dist/nhsuk/index.js",
      "default": "./dist/nhsuk/index.js"
    },
    "./lib": {
      "types": "./dist/nhsuk/lib/index.d.mts",
      "import": "./dist/nhsuk/lib/index.mjs",
      "require": "./dist/nhsuk/lib/index.js",
      "default": "./dist/nhsuk/lib/index.js"
    },
    "./lib/*": "./dist/nhsuk/lib/*",
    "./packages/*": {
      "sass": "./dist/nhsuk/*",
      "default": "./dist/nhsuk/*.js"
    },
    "./packages/*.js": "./dist/nhsuk/*.js",
    "./package.json": "./package.json",
    "./*": {
      "sass": "./dist/nhsuk/*",
      "default": "./*"
    }
  },
  "main": "dist/nhsuk/index.js",
  "module": "dist/nhsuk/index.mjs",
  "sass": "dist/nhsuk/index.scss",
  "types": "dist/nhsuk/index.d.mts",
  "files": [
    "dist",
    "src",
    "!**/fixtures",
    "!**/*.test.*"
  ],
  "scripts": {
    "clean": "del-cli dist",
    "postclean": "tsc --build --clean",
    "build": "gulp build --color",
    "watch": "gulp watch --color",
    "fixtures": "gulp fixtures --color",
    "types": "tsc --build --noEmit false --pretty tsconfig.json",
    "release": "gulp release --color",
    "version": "echo $npm_package_version",
    "start": "npm run watch"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@nhsuk/frontend-config": "*",
    "@nhsuk/frontend-helpers": "*",
    "@nhsuk/frontend-lib": "*",
    "@nhsuk/frontend-tasks": "*",
    "@prettier/sync": "^0.6.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "autoprefixer": "^10.4.27",
    "axe-core": "^4.11.1",
    "cssnano": "^7.1.2",
    "del-cli": "^7.0.0",
    "gulp": "^5.0.1",
    "gulp-zip": "^6.1.0",
    "highlight.js": "^11.11.1",
    "jsdom-testing-mocks": "^1.16.0",
    "nunjucks": "^3.2.4",
    "outdent": "^0.8.0",
    "postcss": "^8.5.6",
    "postcss-scss": "^4.0.9",
    "puppeteer": "^24.37.5",
    "sass-embedded": "^1.97.3",
    "slug": "^11.0.1"
  },
  "peerDependencies": {
    "highlight.js": "^11.0.0",
    "nunjucks": "^3.0.0",
    "outdent": "^0.8.0",
    "@prettier/sync": "^0.6.0",
    "slug": "^9.0.0 || ^11.0.0"
  },
  "peerDependenciesMeta": {
    "highlight.js": {
      "optional": true
    },
    "nunjucks": {
      "optional": true
    },
    "outdent": {
      "optional": true
    },
    "@prettier/sync": {
      "optional": true
    },
    "slug": {
      "optional": true
    }
  },
  "engines": {
    "node": "^20.9.0 || ^22.11.0 || >= 24.11.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
