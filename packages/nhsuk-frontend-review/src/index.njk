{% set title = 'NHS.UK frontend' %}

{% extends 'layouts/page.njk' %}

{% block header %}
  {% call hero({
    heading: "This is an internal development app.",
    headingClasses: "nhsuk-body-l nhsuk-u-font-weight-normal",
    headingLevel: 2
  }) %}
    <p class="nhsuk-u-margin-bottom-0">To learn how to design and build digital services, visit the <a href="https://service-manual.nhs.uk/design-system">design system in the NHS digital service manual</a> for guidance and examples.</p>
  {% endcall %}
{% endblock %}

{% block content %}

  <div class="nhsuk-grid-row">
    <div class="nhsuk-grid-column-two-thirds">
      <h1 class="nhsuk-heading-xl nhsuk-u-margin-bottom-4">NHS.UK frontend</h1>
      <p class="nhsuk-body">Deployed automatically from <a href="https://github.com/nhsuk/nhsuk-frontend/commits/{{ branchName }}" rel="noreferrer noopener" target="_blank"><code>{{ branchName }}</code> branch (opens in new tab).</a></p>

      <h2 class="nhsuk-heading-l">Components and variants</h2>
      <p class="nhsuk-body">These examples are used for automated tests and may not follow service manual best practice.</p>

      <ul class="nhsuk-list">
        {% for data in components %}
          {% for example in data.examples %}
            {% set slug = example.name | slugify if example.name != "default" else "index" %}
            {% set name = data.name ~ " " ~ example.name if example.name != "default" else data.name %}
            <li><a href="components/{{ data.component }}/{{ slug }}.html">{{ name }}</a></li>
          {% endfor %}
        {% endfor %}
      </ul>

      <h2 class="nhsuk-heading-l">Example pages</h2>

      {{ contentsList({
        items: [
          {
            href: "examples/all.html",
            text: "All component examples"
          },
          {
            href: "examples/all-buttons.html",
            text: "All button examples"
          },
          {
            href: "examples/all-links.html",
            text: "All link examples"
          },
          {
            href: "examples/all-tags.html",
            text: "All tag examples"
          },
          {
            href: "examples/card-group.html",
            text: "Card group"
          },
          {
            href: "examples/expander-group.html",
            text: "Expander group"
          },
          {
            href: "examples/expander-alongside-card.html",
            text: "Expander alongside card"
          },
          {
            href: "examples/error-summary-linking-to-input.html",
            text: "Error summary with link to an input field"
          },
          {
            href: "examples/error-summary-linking-to-radios.html",
            text: "Error summary with link to a radio field"
          },
          {
            href: "examples/task-list-multiple-sections.html",
            text: "Task list with multiple sections"
          },
          {
            href: "examples/typography.html",
            text: "Typography and spacing examples"
          }
        ]
      }) }}
    </div>
  </div>

{% endblock %}
