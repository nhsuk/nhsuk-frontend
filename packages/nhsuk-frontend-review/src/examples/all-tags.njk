{% extends "layouts/page-full-width.njk" %}

{% set pageName = "Tags" %}

{% set examples = {
  "Default": {
    text: "Default"
  },
  "White": {
    text: "In progress",
    colour: "white"
  },
  "Grey": {
    text: "Inactive",
    colour: "grey"
  },
  "Green": {
    text: "New",
    colour: "green"
  },
  "Aqua green": {
    text: "Active",
    colour: "aqua-green"
  },
  "Blue": {
    text: "Pending",
    colour: "blue"
  },
  "Purple": {
    text: "Received",
    colour: "purple"
  },
  "Pink": {
    text: "Sent",
    colour: "pink"
  },
  "Red": {
    text: "Rejected",
    colour: "red"
  },
  "Orange": {
    text: "Declined",
    colour: "orange"
  },
  "Yellow": {
    text: "Delayed",
    colour: "yellow"
  }
} %}

{% block beforeContent %}
  {{ breadcrumb({
    items: [
      {
        text: "NHS.UK frontend",
        href: baseUrl
      },
      {
        text: "Examples",
        href: baseUrl ~ "#examples"
      }
    ]
  }) }}
{% endblock %}

{% block content %}
  <section class="nhsuk-main-wrapper nhsuk-main-wrapper--s">
    <div class="nhsuk-width-container">

      <div class="nhsuk-grid-row">
        <div class="nhsuk-grid-column-two-thirds">
          <h1 class="nhsuk-heading-xl">{{ pageName }}</h1>
        </div>
      </div>

      <div class="nhsuk-grid-row">
        <div class="nhsuk-grid-column-two-thirds">
          {% set rows = [] %}

          {% for name, params in examples %}
            {% set colourHtml %}
              {% if params.colour %}
                <var class="nhsuk-body-s">{{ params.colour }}</var>
              {% else %}
                None
              {% endif %}
            {% endset %}

            {% set tagHtml %}
              {{ tag({
                text: params.text,
                colour: params.colour
              }) }}
            {% endset %}

            {% set rows = (rows.push([
              { text: name, header: "Name" },
              { html: colourHtml, header: "Colour" },
              { html: tagHtml, header: "Tag" }
            ]), rows) %}
          {% endfor %}

          {{ table({
            caption: "Page background",
            captionClasses: "nhsuk-u-margin-bottom-4",
            captionSize: "l",
            firstCellIsHeader: true,
            responsive: true,
            head: [
              {
                text: "Name",
                classes: "nhsuk-u-width-one-third"
              },
              {
                text: "Colour",
                classes: "nhsuk-u-width-one-third"
              },
              {
                text: "Tag",
                classes: "nhsuk-u-width-one-third"
              }
            ],
            rows: rows
          }) }}

        </div>
      </div>

    </div>
  </section>

  <section class="nhsuk-main-wrapper app-wrapper app-wrapper--background-blue">
    <div class="nhsuk-width-container">

      <div class="nhsuk-grid-row">
        <div class="nhsuk-grid-column-two-thirds">
          {% set rows = [] %}

          {% for name, params in examples %}
            {% set colourHtml %}
              {% if params.colour %}
                <var class="nhsuk-body-s">{{ params.colour }}</var>
              {% else %}
                None
              {% endif %}
            {% endset %}

            {% set tagHtml %}
              {{ tag({
                text: params.text,
                colour: params.colour,
                border: false
              }) }}
            {% endset %}

            {% set rows = (rows.push([
              { text: name, header: "Name" },
              { html: colourHtml, header: "Colour" },
              { html: tagHtml, header: "Tag" }
            ]), rows) %}
          {% endfor %}

          {{ table({
            caption: "Blue background (used in hero)",
            captionClasses: "nhsuk-u-margin-bottom-4",
            captionSize: "l",
            firstCellIsHeader: true,
            responsive: true,
            variant: "reverse",
            head: [
              {
                text: "Name",
                classes: "nhsuk-u-width-one-third"
              },
              {
                text: "Colour",
                classes: "nhsuk-u-width-one-third"
              },
              {
                text: "Tag",
                classes: "nhsuk-u-width-one-third"
              }
            ],
            rows: rows
          }) }}

        </div>
      </div>

    </div>
  </section>
{% endblock %}
