{% extends "layouts/page.njk" %}

{% set pageName = "Form elements alignment" %}
{% set mainClasses = "nhsuk-main-wrapper--s" %}

{% block beforeContent %}
  {{ breadcrumb({
    classes: "nhsuk-u-display-inline-block",
    items: [
      {
        text: "NHS.UK frontend",
        href: baseUrl
      },
      {
        text: "Examples",
        href: baseUrl ~ "#examples"
      }
    ]
  }) }}
{% endblock %}

{% block content %}
  <div class="nhsuk-grid-row">
    <div class="nhsuk-grid-column-two-thirds">
      <h1 class="nhsuk-heading-xl">{{ pageName }}</h1>
    </div>
  </div>

  <div class="nhsuk-grid-row">
    <div class="nhsuk-grid-column-full">

      <form method="post" novalidate>
        {% call fieldset({
          legend: {
            text: "Input and buttons",
            classes: 'nhsuk-fieldset__legend--m'
          }
        }) %}
          {{ label({
            text: "NHS number",
            for: "example-input"
          }) }}

          <div class="nhsuk-form-group-row nhsuk-u-width-two-thirds">
            {{ input({
              name: "example-input",
              id: "example-input",
              classes: "nhsuk-u-width-full"
            }) }}

            {{ button({
              text: "Search",
              classes: "nhsuk-button--secondary nhsuk-button--small"
            }) }}
          </div>
        {% endcall %}
      </form>

      <hr class="nhsuk-section-break nhsuk-section-break--m">

      <form method="post" novalidate>
        {% call fieldset({
          legend: {
            text: "Select and button",
            classes: 'nhsuk-fieldset__legend--m'
          }
        }) %}
          {{ label({
            text: "Sort by",
            for: "sort-by"
          }) }}

          <div class="nhsuk-form-group-row">
            {{ select({
              name: "sort-by",
              id: "sort-by",
              classes: "nhsuk-u-width-full",
              items: [
                {
                  value: 'published',
                  text: 'Recently published'
                },
                {
                  value: 'updated',
                  text: 'Recently updated'
                },
                {
                  value: 'views',
                  text: 'Most views'
                },
                {
                  value: 'comments',
                  text: 'Most comments'
                }
              ]
            }) }}

            {{ button({
              text: "Sort",
              classes: "nhsuk-button--secondary nhsuk-button--small"
            }) }}
          </div>
        {% endcall %}
      </form>

      <hr class="nhsuk-section-break nhsuk-section-break--m">

      <form method="post" novalidate>
        {% call fieldset({
          legend: {
            text: "Input and select",
            classes: 'nhsuk-fieldset__legend--m'
          }
        }) %}
          <div class="nhsuk-form-group-row">
            {{ input({
              label: {
                text: "Keywords"
              },
              id: "keywords-group"
            }) }}

            {{ select({
              label: {
                text: "Sort by"
              },
              id: "sort-by-group",
              name: "sort-by-group",
              items: [
                {
                  value: 'published',
                  text: 'Recently published'
                },
                {
                  value: 'updated',
                  text: 'Recently updated'
                },
                {
                  value: 'views',
                  text: 'Most views'
                },
                {
                  value: 'comments',
                  text: 'Most comments'
                }
              ]
            }) }}
          </div>
        {% endcall %}
      </form>

      <hr class="nhsuk-section-break nhsuk-section-break--m">

      <form method="post" novalidate>
        {% call fieldset({
          legend: {
            text: "Input and checkboxes",
            classes: 'nhsuk-fieldset__legend--m'
          }
        }) %}
          {{ label({
            text: "Keywords",
            for: "keywords-checkboxes"
          }) }}

          <div class="nhsuk-form-group-row">
            {{ input({
              id: "keywords-checkboxes"
            }) }}

            {{ checkboxes({
              name: "checkboxes",
              idPrefix: "checkboxes",
              items: [
                {
                  text: "Show archived",
                  value: "archived"
                }
              ]
            }) }}
          </div>
        {% endcall %}
      </form>

      <hr class="nhsuk-section-break nhsuk-section-break--m">

      <form method="post" novalidate>
        {% call fieldset({
          legend: {
            text: "Input and radios",
            classes: 'nhsuk-fieldset__legend--m'
          }
        }) %}
          {{ label({
            text: "Keywords",
            for: "keywords-radios"
          }) }}

          <div class="nhsuk-form-group-row">
            {{ input({
              id: "keywords-radios"
            }) }}

            {{ radios({
              name: "radios",
              idPrefix: "radios",
              items: [
                {
                  text: "Not applicable",
                  value: "na"
                }
              ]
            }) }}
          </div>
        {% endcall %}
      </form>

      <hr class="nhsuk-section-break nhsuk-section-break--m">

      <form method="post" novalidate>
        {% call fieldset({
          legend: {
            text: "Checkboxes, radios and button",
            classes: 'nhsuk-fieldset__legend--m'
          }
        }) %}
          <div class="nhsuk-form-group-row">
            {{ checkboxes({
              name: "checkboxes-group",
              idPrefix: "checkboxes-group",
              items: [
                {
                  text: "Show archived",
                  value: "archived"
                }
              ]
            }) }}

            {{ radios({
              name: "radios-group",
              idPrefix: "radios-group",
              items: [
                {
                  text: "Not applicable",
                  value: "na"
                }
              ]
            }) }}

            {{ button({
              text: "Save",
              classes: "nhsuk-button--secondary nhsuk-button--small"
            }) }}
          </div>
        {% endcall %}
      </form>

      <hr class="nhsuk-section-break nhsuk-section-break--m">

      <form method="post" novalidate>
        {% call fieldset({
          legend: {
            text: "Input with nhsuk-u-width classes",
            classes: 'nhsuk-fieldset__legend--m'
          }
        }) %}
          {{ input({
            label: {
              text: "Input with nhsuk-u-width-one-quarter (25% width)"
            },
            id: "nhsuk-u-width-one-quarter",
            classes: "nhsuk-u-width-one-quarter"
          }) }}

          {{ input({
            label: {
              text: "Input with nhsuk-u-width-one-third (33% width)"
            },
            id: "nhsuk-u-width-one-third",
            classes: "nhsuk-u-width-one-third"
          }) }}

          {{ input({
            label: {
              text: "Input with nhsuk-u-width-one-half (50% width)"
            },
            id: "nhsuk-u-width-one-half",
            classes: "nhsuk-u-width-one-half"
          }) }}

          {{ input({
            label: {
              text: "Input with nhsuk-u-width-two-thirds (66% width)"
            },
            id: "nhsuk-u-width-two-thirds",
            classes: "nhsuk-u-width-two-thirds"
          }) }}

          {{ input({
            label: {
              text: "Input with nhsuk-u-width-width-three-quarters (75% width)"
            },
            id: "nhsuk-u-width-three-quarters",
            classes: "nhsuk-u-width-three-quarters"
          }) }}
        {% endcall %}

        <div class="nhsuk-button-group">
          {{ button({
            text: "Continue"
          }) }}
        </div>
      </form>
    </div>
  </div>
{% endblock %}
