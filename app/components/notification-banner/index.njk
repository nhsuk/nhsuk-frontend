{% set title = 'Notification banner' %}
{% from 'components/notification-banner/macro.njk' import notificationBanner %}
{% extends 'example.njk' %}

{% block content %}

  <div class="nhsuk-grid-row">
    <div class="nhsuk-grid-column-two-thirds">
      {% call notificationBanner() %}
        <p class="nhsuk-notification-banner__heading">
          You have 7 days left to send your application.
          <a class="nhsuk-notification-banner__link" href="#">View application</a>.
        </p>
      {% endcall %}
    </div>
  </div>

{% endblock %}
