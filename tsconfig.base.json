{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "module": "NodeNext",
    "noEmit": true,
    "paths": {
      "nhsuk-frontend": ["./packages/nhsuk.js"],
      "nhsuk-frontend/*": ["./*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "strictBindCallApply": true,
    "strictFunctionTypes": true,
    "types": [
      "@testing-library/jest-dom",
      "jest",
      "jest-puppeteer",
      "node",
      "typed-query-selector"
    ]
  },
  "exclude": ["**/node_modules", "**/dist"],
  "typeAcquisition": {
    "enable": false
  }
}
